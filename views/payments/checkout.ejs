<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col pb-8 zilo-page-enter" id="checkoutPage"
  data-request-id="<%= request.id %>"
  data-can-welcome="<%= summary.canUseWelcome %>">

  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center gap-3">
      <a href="/cliente/servicio/<%= request.serviceId %>" class="w-10 h-10 rounded-full zilo-card-premium flex items-center justify-center">
        <svg class="w-5 h-5 text-zilo-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <p class="zilo-label">Checkout</p>
        <h1 class="font-semibold"><%= service.name %></h1>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 space-y-4">
    <div class="zilo-card-premium rounded-2xl p-5">
      <p class="text-xs text-zilo-muted mb-1"><%= request.address %></p>
      <% if (request.urgencyTierLabel) { %>
        <p class="text-xs text-zilo-accent mt-2">Urgencia: <strong><%= request.urgencyTierLabel %></strong></p>
      <% } %>
      <% if (request.isGift) { %>
        <p class="text-xs text-zilo-accent mt-2">Regalo para <strong><%= request.beneficiaryName %></strong></p>
      <% } %>
    </div>

    <!-- Descuentos -->
    <section class="zilo-card-premium rounded-2xl p-5 space-y-4">
      <h2 class="zilo-label">Beneficios Fundez</h2>

      <% if (summary.canUseWelcome) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer">
        <div>
          <strong class="text-sm block">Código BIENVENIDO</strong>
          <span class="text-xs text-zilo-muted">20% en tu primer servicio</span>
        </div>
        <input type="checkbox" id="usePromo" class="w-5 h-5 rounded accent-[#2563EB]">
      </label>
      <% } %>

      <% if (mod('client_puntos') && referral.creditsCLP > 0) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer pt-3 border-t border-gray-200">
        <div>
          <strong class="text-sm block">Usar crédito</strong>
          <span class="text-xs text-zilo-success"><%= formatCLP(referral.creditsCLP) %> disponible</span>
        </div>
        <input type="checkbox" id="useCredits" class="w-5 h-5 rounded accent-[#2563EB]" checked>
      </label>
      <% } %>

      <% if (mod('client_puntos') && referral.points > 0) { %>
      <label class="flex items-center justify-between gap-3 cursor-pointer pt-3 border-t border-gray-200">
        <div>
          <strong class="text-sm block">Canjear Puntos Fundez</strong>
          <span class="text-xs text-zilo-muted"><%= referral.points %> pts = <%= formatCLP(referral.points * pointsValue) %></span>
        </div>
        <input type="checkbox" id="usePoints" class="w-5 h-5 rounded accent-[#2563EB]">
      </label>
      <% } %>

      <div class="pt-3 border-t border-gray-200">
        <label class="zilo-label block mb-2">Código promocional</label>
        <div class="flex gap-2">
          <input type="text" id="promoCode" placeholder="BIENVENIDO" maxlength="12"
            class="zilo-input flex-1 uppercase font-mono text-sm">
          <button type="button" id="btnApplyPromo" class="zilo-btn-ghost shrink-0">Aplicar</button>
        </div>
      </div>
    </section>

    <!-- Resumen -->
    <section class="zilo-card-premium rounded-2xl p-5" id="summaryBox">
      <h2 class="zilo-label mb-4">Resumen</h2>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between checkout-line pb-2">
          <span class="text-zilo-muted">Visita técnica (base)</span>
          <span id="lineVisitBase"><%= formatCLP(summary.visitBasePrice || summary.basePrice) %></span>
        </div>
        <% if (summary.urgencyAdjustmentAmount) { %>
        <div class="flex justify-between checkout-line pb-2" id="lineUrgencyRow">
          <span class="text-zilo-muted" id="lineUrgencyLabel"><%= summary.urgencyTierLabel || 'Ajuste urgencia' %></span>
          <span id="lineUrgency" class="<%= summary.urgencyAdjustmentAmount > 0 ? 'text-orange-600' : 'text-emerald-600' %>"><%= summary.urgencyAdjustmentAmount > 0 ? '+' : '' %><%= formatCLP(summary.urgencyAdjustmentAmount) %></span>
        </div>
        <% } else { %>
        <div class="flex justify-between checkout-line pb-2 hidden" id="lineUrgencyRow">
          <span class="text-zilo-muted" id="lineUrgencyLabel">Ajuste urgencia</span>
          <span id="lineUrgency">—</span>
        </div>
        <% } %>
        <div class="flex justify-between checkout-line pb-2 border-b border-zilo-border">
          <span class="text-zilo-muted font-medium">Visita a pagar ahora</span>
          <span id="lineBase" class="font-medium"><%= formatCLP(summary.basePrice) %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 text-zilo-muted/80">
          <span class="text-xs">Servicio estimado <span class="text-[10px]">(se paga en sitio)</span></span>
          <span id="lineService" class="text-xs"><%= formatCLP(summary.servicePriceBase || 0) %></span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="linePromoRow">
          <span class="text-zilo-muted">Promoción</span>
          <span id="linePromo" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="lineCreditsRow">
          <span class="text-zilo-muted">Crédito Fundez</span>
          <span id="lineCredits" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between checkout-line pb-2 hidden" id="linePointsRow">
          <span class="text-zilo-muted">Puntos canjeados</span>
          <span id="linePoints" class="checkout-discount">—</span>
        </div>
        <div class="flex justify-between pt-2">
          <strong>Total a pagar</strong>
          <strong class="text-zilo-accent text-lg" id="lineTotal"><%= formatCLP(summary.amountDue) %></strong>
        </div>
      </div>
    </section>

    <% if (!mpConfigured) { %>
    <p class="text-xs text-zilo-warning/90 p-3 rounded-xl border border-zilo-warning/20 bg-zilo-warning/5 text-center">
      Modo demo — Mercado Pago no configurado
    </p>
    <% } %>

    <button type="button" id="btnPay" class="zilo-btn-primary">
      <span id="btnPayLabel">Pagar <%= formatCLP(summary.amountDue) %></span>
    </button>
    <a href="/cliente" class="block text-center text-sm text-zilo-muted hover:text-gray-700 py-2">Cancelar</a>
  </main>
</div>

<script>
(function () {
  const page = document.getElementById('checkoutPage');
  const requestId = page.dataset.requestId;
  const fmt = n => new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 }).format(n);

  const usePromo = document.getElementById('usePromo');
  const useCredits = document.getElementById('useCredits');
  const usePoints = document.getElementById('usePoints');
  const promoCode = document.getElementById('promoCode');
  const btnPay = document.getElementById('btnPay');

  async function recalc() {
    const code = promoCode.value.trim() || (usePromo?.checked ? 'BIENVENIDO' : '');
    const res = await fetch('/pagos/calcular', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        requestId,
        useCredits: useCredits?.checked,
        usePoints: usePoints?.checked,
        promoCode: code
      })
    });
    const data = await res.json();
    if (!data.success) {
      FundezNotify.show(data.error || 'Error al calcular', 'warning');
      return;
    }
    const s = data.summary;
    document.getElementById('lineVisitBase').textContent = fmt(s.visitBasePrice || s.basePrice);
    document.getElementById('lineBase').textContent = fmt(s.basePrice);
    if (s.servicePriceBase) document.getElementById('lineService').textContent = fmt(s.servicePriceBase);
    const urgRow = document.getElementById('lineUrgencyRow');
    if (urgRow && s.urgencyAdjustmentAmount) {
      urgRow.classList.remove('hidden');
      const urgEl = document.getElementById('lineUrgency');
      urgEl.textContent = (s.urgencyAdjustmentAmount > 0 ? '+' : '') + fmt(s.urgencyAdjustmentAmount);
      if (s.urgencyTierLabel) document.getElementById('lineUrgencyLabel').textContent = s.urgencyTierLabel;
    }
    document.getElementById('lineTotal').textContent = fmt(s.amountDue);
    document.getElementById('btnPayLabel').textContent = s.amountDue === 0 ? 'Confirmar servicio gratis' : `Pagar ${fmt(s.amountDue)}`;

    const show = (id, val) => {
      const row = document.getElementById(id + 'Row');
      const el = document.getElementById(id);
      if (val > 0) { row.classList.remove('hidden'); el.textContent = '−' + fmt(val); }
      else row.classList.add('hidden');
    };
    show('linePromo', s.discountPromo);
    show('lineCredits', s.discountCredits);
    show('linePoints', s.discountPoints);
  }

  [usePromo, useCredits, usePoints].forEach(el => el?.addEventListener('change', recalc));
  document.getElementById('btnApplyPromo')?.addEventListener('click', recalc);

  btnPay.addEventListener('click', async () => {
    btnPay.disabled = true;
    const code = promoCode.value.trim() || (usePromo?.checked ? 'BIENVENIDO' : '');
    const res = await fetch('/pagos/crear', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        requestId,
        useCredits: useCredits?.checked,
        usePoints: usePoints?.checked,
        promoCode: code
      })
    });
    const data = await res.json();
    if (!data.success) {
      btnPay.disabled = false;
      FundezNotify.show(data.error || 'Error', 'error');
      return;
    }
    if (data.free) window.location.href = data.redirect;
    else window.location.href = data.checkoutUrl;
  });

  recalc();
})();
</script>

<%- include('../partials/footer') %>
