<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col items-center justify-center p-6 text-center">
  <div class="w-20 h-20 rounded-full bg-emerald-500/20 flex items-center justify-center mb-6 animate-bounce-in">
    <svg class="w-10 h-10 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
  </div>
  <h1 class="text-2xl font-bold mb-2">¡Pago confirmado!</h1>
  <p class="text-white/50 mb-2">Tu visita técnica está siendo procesada</p>
  <% if (request) { %>
    <p class="text-emerald-400 font-bold text-lg mb-6"><%= formatCLP(request.estimatedVisit) %></p>

    <% if (request.coords) { %>
    <div id="paymentMap" class="w-full h-48 rounded-2xl overflow-hidden border border-white/10 mb-6"
      data-lat="<%= request.coords.lat %>" data-lng="<%= request.coords.lng %>" data-label="<%= request.address %>"></div>
    <% } %>

    <a href="/cliente/servicio/<%= request.serviceId %>?tracking=<%= request.id %>"
      class="w-full py-4 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 font-semibold shadow-xl shadow-blue-600/30">
      Ver estado del servicio
    </a>
  <% } else { %>
    <a href="/cliente" class="w-full py-4 rounded-full bg-gradient-to-r from-blue-600 to-blue-500 font-semibold">Volver al inicio</a>
  <% } %>
</div>

<script src="/js/map.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('paymentMap');
    if (el) ZiloMap.init(el, { lat: el.dataset.lat, lng: el.dataset.lng, label: el.dataset.label, zoom: 15 });
  });
</script>

<%- include('../partials/footer') %>
