<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col zilo-page-enter" id="tecnicoPage" data-tecnico-id="<%= tecnico.id %>">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-zilo-border px-5 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-11 h-11 rounded-xl zilo-card-premium flex items-center justify-center text-sm font-semibold text-zilo-accent border border-zilo-accent/25">
          <%= tecnico.avatar %>
        </div>
        <div>
          <p class="zilo-label !text-[9px]"><%= t('tecnico.subtitle') %><%= socio ? ' · ' + socio.name : '' %></p>
          <h1 class="text-base font-semibold"><%= tecnico.name %></h1>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <%- include('../partials/lang-switcher') %>
        <a href="/logout" class="zilo-icon-btn" title="<%= t('common.logout') %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        </a>
      </div>
    </div>
  </header>

  <main class="flex-1 px-5 py-5 pb-10">
    <section class="flex items-center justify-between p-5 rounded-2xl zilo-card-premium mb-5" data-tour="tech-online">
      <div class="flex items-center gap-3">
        <div id="techStatusDot" class="w-3 h-3 rounded-full <%= tecnico.online ? 'bg-zilo-success shadow-lg shadow-zilo-success/40 animate-pulse' : 'bg-zilo-muted/40' %>"></div>
        <div>
          <h2 id="techStatusText" class="font-semibold text-sm"><%= tecnico.online ? t('tecnico.online') : t('tecnico.offline') %></h2>
          <p id="techStatusSub" class="text-xs text-zilo-muted"><%= tecnico.online ? t('tecnico.online_sub') : t('tecnico.offline_sub') %></p>
        </div>
      </div>
      <label class="toggle-ios">
        <input type="checkbox" id="techOnlineToggle" <%= tecnico.online ? 'checked' : '' %>>
        <span class="slider"></span>
      </label>
    </section>

    <div class="mb-5">
      <%- include('../partials/password-form') %>
    </div>

    <div class="mb-5">
      <%- include('../partials/guide-card', {
        summary: t('tecnico.guide.summary'),
        linkText: t('tecnico.guide.link')
      }) %>
    </div>

    <section id="techWorkWall" class="mb-6" data-tour="tech-wall">
      <div class="flex items-center justify-between mb-3">
        <p class="zilo-label"><%= t('tecnico.wall_title') %></p>
        <span id="techWorkWallCount" class="text-xs font-semibold text-zilo-accent">0</span>
      </div>
      <p class="text-xs text-zilo-muted mb-3"><%= t('tecnico.wall_hint') %></p>
      <div id="techWorkWallEmpty" class="zilo-empty zilo-card-premium rounded-2xl">
        <p class="zilo-display text-base"><%= t('tecnico.dashboard.no_requests') %></p>
        <p class="text-sm"><%= t('tecnico.wall_empty_sub') %></p>
      </div>
      <div id="techWorkWallList" class="space-y-2"></div>
    </section>

    <p class="zilo-label mb-3" data-tour="tech-jobs"><%= t('tecnico.assigned_title') %></p>

    <% if (!jobs || jobs.length === 0) { %>
      <div class="zilo-empty zilo-card-premium rounded-2xl">
        <p class="zilo-display"><%= t('tecnico.no_jobs') %></p>
        <p class="text-sm"><%= t('tecnico.no_jobs_sub') %></p>
      </div>
    <% } else { %>
      <div class="space-y-3" id="jobList">
        <% jobs.forEach(j => { %>
          <div class="p-4 rounded-2xl zilo-card-premium"
               data-job-id="<%= j.id %>"
               data-tech-status="<%= j.techStatus %>"
               <% if (j.coords) { %>data-lat="<%= j.coords.lat %>" data-lng="<%= j.coords.lng %>"<% } %>>
            <div class="flex justify-between items-start mb-2">
              <div class="min-w-0">
                <strong class="text-sm block truncate"><%= j.serviceName %></strong>
                <span class="text-xs text-zilo-muted block truncate">
                  <% if (j.isGift && j.beneficiaryName) { %><%= t('tecnico.gift') %> · <%= j.beneficiaryName %><% } else { %><%= j.clientName %><% } %>
                </span>
              </div>
              <span class="zilo-badge zilo-badge-muted shrink-0" data-role="status"><%= techLabels[j.techStatus] || j.techStatus %></span>
            </div>

            <p class="text-xs text-zilo-muted/90 mb-2 flex items-start gap-1">
              <svg class="w-3.5 h-3.5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span><%= j.address || t('tecnico.no_address') %></span>
            </p>
            <% if (j.notes) { %>
              <p class="text-xs text-zilo-muted italic p-2.5 rounded-lg bg-zilo-bg/80 border border-zilo-border mb-3"><%= j.notes %></p>
            <% } %>
            <% if (j.clientPhotoUrl || j.clientBrandPhotoUrl || j.brandNotVisible) { %>
              <p class="text-[10px] text-zilo-accent mb-2 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <%= t('tecnico.client_photo') %><% if (j.brandNotVisible) { %> · <%= t('tecnico.brand_not_visible') %><% } %>
              </p>
            <% } %>

            <div class="flex gap-2" data-role="actions"></div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>
</div>

<%- include('../partials/guide-modal', {
  role: 'tecnico',
  title: 'Procedimiento de atención Fundez',
  steps: [
    { title: 'Disponibilidad', body: 'Activa el modo en línea para ver el muro. Sin estar en línea no recibes trabajos nuevos.', tip: 'Activa notificaciones del navegador (sonido y vibración).' },
    { title: 'Tomar un trabajo', body: 'Revisa dirección, notas y fotos del cliente. El primero que acepta se queda con el servicio.', tip: 'No aceptes si no puedes llegar a tiempo.' },
    { title: 'En domicilio (nivel europeo)', body: 'Puntualidad · Presentación con nombre y Fundez · Permiso de ingreso · Explicar diagnóstico · Aprobación antes de sobrecosto · Foto inicio/fin · Limpieza · Despedida y pedir calificación.', tip: 'Usa el checklist en la pantalla de la visita.' },
    { title: 'Estados', body: 'En camino → En sitio → Diagnóstico → presupuesto si aplica → Completar. Cada cambio informa al cliente vía Aland IA.', tip: 'Nunca cobres extras sin aprobación en la app.' }
  ],
  extras: [
    { title: 'Sin sesgos', body: 'Trata cada caso por los hechos. No asumas capacidad de pago ni urgencias inventadas.' },
    { title: 'Calidad', body: 'El estándar Fundez es el de un servicio europeo: respeto al hogar, claridad y cierre limpio.' }
  ]
}) %>

<%- include('../partials/onboarding-tour') %>

<%- include('../partials/footer', { pageScript: '/js/tecnico.js' }) %>
<script src="/js/guide.js"></script>
<script src="/js/map.js"></script>
