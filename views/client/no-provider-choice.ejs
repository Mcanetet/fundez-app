<%- include('../partials/head') %>

<div class="max-w-lg mx-auto min-h-screen px-5 py-10 flex items-center">
  <main class="w-full zilo-card-premium rounded-3xl p-6 border border-violet-200">
    <div class="w-12 h-12 rounded-2xl bg-violet-100 text-violet-700 flex items-center justify-center mb-4">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
      </svg>
    </div>

    <% if (typeof completed !== 'undefined' && completed) { %>
      <p class="zilo-label text-violet-700 mb-1">Aland IA</p>
      <h1 class="text-xl font-semibold mb-3">Recibimos tu elección</h1>
      <% if (selectedChoice === 'refund') { %>
        <p class="text-sm text-zilo-muted leading-relaxed">
          La devolución de <strong><%= request.serviceName %></strong> quedó solicitada para el siguiente día hábil
          (<strong><%= request.refundScheduledDate %></strong>). Administración procesará el abono al mismo medio de pago.
        </p>
      <% } else { %>
        <p class="text-sm text-zilo-muted leading-relaxed">
          Seguiremos intentando encontrar un socio para <strong><%= request.serviceName %></strong> y te avisaremos apenas alguien tome la solicitud.
        </p>
      <% } %>
      <a href="/cliente" class="mt-6 block w-full text-center py-3 rounded-xl bg-zilo-accent text-white text-sm font-semibold">Ir a la app</a>
    <% } else { %>
      <p class="zilo-label text-violet-700 mb-1">Mensaje de Aland IA</p>
      <h1 class="text-xl font-semibold mb-3">Aún no encontramos un socio</h1>
      <p class="text-sm text-zilo-muted leading-relaxed mb-5">
        Han pasado más de 10 minutos y todavía nadie ha tomado tu solicitud de
        <strong><%= request.serviceName %></strong>. Elige qué deseas hacer:
      </p>

      <form method="POST" action="/cliente/solicitud/<%= request.id %>/sin-socio" class="space-y-3">
        <input type="hidden" name="token" value="<%= token %>">
        <button type="submit" name="choice" value="continue"
          class="w-full text-left p-4 rounded-2xl border <%= selectedChoice === 'continue' ? 'border-blue-500 bg-blue-50' : 'border-gray-200 bg-white' %> hover:border-blue-400 transition">
          <strong class="text-sm block text-blue-700">Seguir intentando</strong>
          <span class="text-xs text-zilo-muted">La solicitud seguirá visible para los socios disponibles.</span>
        </button>
        <button type="submit" name="choice" value="refund"
          class="w-full text-left p-4 rounded-2xl border <%= selectedChoice === 'refund' ? 'border-red-500 bg-red-50' : 'border-gray-200 bg-white' %> hover:border-red-400 transition">
          <strong class="text-sm block text-red-700">Solicitar devolución</strong>
          <span class="text-xs text-zilo-muted">Quedará programada para el siguiente día hábil y se procesará al mismo medio de pago.</span>
        </button>
      </form>
    <% } %>
  </main>
</div>

<%- include('../partials/footer') %>
