<%- include('../partials/head', { useMap: true }) %>

<div class="max-w-lg mx-auto min-h-screen flex flex-col" id="servicePage"
  data-service-id="<%= service.id %>"
  data-visit-price="<%= service.visitPrice %>"
  data-tracking="<%= typeof tracking !== 'undefined' ? tracking : '' %>">
  <header class="sticky top-0 z-50 bg-zilo-bg/90 backdrop-blur-xl border-b border-white/8 px-4 py-3 flex items-center gap-3">
    <a href="/cliente" class="w-10 h-10 rounded-full bg-zilo-card border border-white/8 flex items-center justify-center">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="flex-1 text-center font-semibold"><%= service.name %></h1>
    <div class="w-10"></div>
  </header>

  <main class="flex-1 px-5 py-5 pb-8">
    <div class="text-center p-6 rounded-2xl bg-zilo-card border border-white/8 mb-5 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-blue-500/10 to-transparent pointer-events-none"></div>
      <span class="text-5xl block mb-3 relative"><%= service.icon %></span>
      <p class="text-white/60 text-sm relative"><%= service.description %></p>
    </div>

    <div class="p-5 rounded-2xl bg-zilo-card border border-white/8 mb-5">
      <h3 class="text-xs text-white/40 font-medium mb-4 uppercase tracking-wider">Precios estimados — Santiago</h3>
      <div class="flex justify-between py-3 border-b border-white/8">
        <span class="text-white/60 text-sm">Visita técnica</span>
        <strong class="text-emerald-400 font-bold"><%= formatCLP(service.visitPrice) %></strong>
      </div>
      <div class="flex justify-between py-3">
        <span class="text-white/60 text-sm">Servicios básicos</span>
        <strong class="text-emerald-400 font-bold"><%= formatCLP(service.basicMin) %> – <%= formatCLP(service.basicMax) %></strong>
      </div>
      <p class="text-[11px] text-white/30 mt-3">* Pago de visita vía Mercado Pago. El técnico confirmará el valor final en sitio.</p>
    </div>

    <section id="requestForm" class="space-y-4">
      <div>
        <label for="address" class="block text-xs font-medium text-white/50 mb-1.5">Dirección del servicio</label>
        <input type="text" id="address" placeholder="Ej: Av. Providencia 1234, Depto 501"
          class="w-full px-4 py-3.5 rounded-xl bg-zilo-bg border border-white/10 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition">
        <input type="hidden" id="lat">
        <input type="hidden" id="lng">
      </div>

      <!-- Mapa real OpenStreetMap -->
      <div>
        <label class="block text-xs font-medium text-white/50 mb-1.5">Ubicación en mapa</label>
        <div id="addressMap" class="w-full h-44 rounded-2xl overflow-hidden border border-white/10 bg-zilo-bg"></div>
        <p id="mapStatus" class="text-[10px] text-white/30 mt-1.5">Escribe una dirección para ver la ubicación</p>
      </div>

      <div>
        <label for="notes" class="block text-xs font-medium text-white/50 mb-1.5">Detalle (opcional)</label>
        <textarea id="notes" rows="3" placeholder="Describe el problema..."
          class="w-full px-4 py-3.5 rounded-xl bg-zilo-bg border border-white/10 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition resize-none"></textarea>
      </div>

      <button type="button" id="btnRequest"
        class="w-full py-4 rounded-full bg-gradient-to-r from-[#009EE3] to-blue-600 font-semibold text-lg shadow-xl shadow-blue-600/30 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
        Pagar <%= formatCLP(service.visitPrice) %> y Solicitar
      </button>
    </section>

    <div id="loaderOverlay" class="hidden fixed inset-0 z-[200] bg-zilo-bg/95 backdrop-blur-md flex items-center justify-center animate-fade-in">
      <div class="text-center px-6 max-w-xs">
        <div class="relative w-28 h-28 mx-auto mb-6">
          <div class="absolute inset-0 border-2 border-blue-500 rounded-full animate-radar"></div>
          <div class="absolute inset-0 border-2 border-blue-500 rounded-full animate-radar" style="animation-delay:0.6s"></div>
          <div class="absolute inset-0 border-2 border-blue-500 rounded-full animate-radar" style="animation-delay:1.2s"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-4 h-4 bg-blue-500 rounded-full shadow-lg shadow-blue-500/50 animate-pulse"></div>
          </div>
        </div>
        <h3 id="loaderText" class="text-lg font-semibold mb-2">Buscando proveedor cercano...</h3>
        <p id="loaderSub" class="text-sm text-white/40 mb-6">Usando tu ubicación en Santiago</p>
        <div class="space-y-2 text-left">
          <div id="step1" class="step-item px-4 py-2.5 rounded-xl bg-blue-500/15 border border-blue-500/30 text-sm text-blue-300">📍 Localizando</div>
          <div id="step2" class="step-item px-4 py-2.5 rounded-xl bg-zilo-card border border-white/8 text-sm text-white/40">🔍 Buscando técnicos</div>
          <div id="step3" class="step-item px-4 py-2.5 rounded-xl bg-zilo-card border border-white/8 text-sm text-white/40">✓ Asignando proveedor</div>
        </div>
      </div>
    </div>

    <section id="providerCard" class="hidden mt-5 p-5 rounded-2xl bg-zilo-card border border-white/8 animate-slide-up">
      <div id="trackingMap" class="w-full h-40 rounded-xl overflow-hidden border border-white/10 mb-4 hidden"></div>
      <div class="flex items-center gap-3 mb-4">
        <div id="providerAvatar" class="w-14 h-14 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center font-bold text-lg">—</div>
        <div class="flex-1">
          <h3 id="providerName" class="font-semibold">—</h3>
          <div class="flex items-center gap-1.5 text-sm">
            <span id="providerStars" class="text-yellow-400">★★★★★</span>
            <span id="providerRating" class="font-medium">—</span>
            <span id="providerReviews" class="text-white/40 text-xs">—</span>
          </div>
        </div>
        <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-blue-500/15 text-blue-300">Asignado</span>
      </div>
      <p id="providerBio" class="text-sm text-white/60 mb-4"></p>
      <h4 class="text-xs text-white/40 uppercase tracking-wider mb-3">Valoraciones recientes</h4>
      <div id="reviewsList" class="space-y-2 mb-4"></div>
      <a id="providerPhone" href="tel:" class="flex items-center justify-center gap-2 w-full py-3.5 rounded-full bg-zilo-elevated border border-white/10 font-medium hover:bg-white/5 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Llamar al proveedor
      </a>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/client.js' }) %>
<script src="/js/map.js"></script>
