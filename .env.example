PORT=3000
# Clave de sesión (obligatoria en producción, mín. 24 caracteres aleatorios)
SESSION_SECRET=genera-una-clave-larga-y-aleatoria-aqui
NODE_ENV=production

# Modo de plataforma: demo | production
# demo = pagos simulados (pruebas). production = pagos reales obligatorios.
APP_MODE=demo
# En producción, para permitir cambiar modo desde el panel admin (no recomendado):
# ALLOW_APP_MODE_TOGGLE=true

# Ruta secreta del panel admin (OBLIGATORIO cambiar en producción).
# Login: https://tudominio.cl/ops-dde167af2c3bc7dd/login
# Generar otra: node scripts/print-admin-url.js --suggest
# No uses /admin en producción (es fácil de adivinar). /admin responde 404 si defines otra ruta.
ADMIN_PATH=/ops-dde167af2c3bc7dd

# MySQL (obligatorio — Hostinger)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario_db
DB_PASSWORD=TU_CLAVE

# URL pública (obligatorio en producción)
APP_URL=https://tudominio.cl

# Admin inicial (en producción ADMIN_PASSWORD es obligatoria y distinta de admin123)
ADMIN_EMAIL=admin@fundez.cl
ADMIN_PASSWORD=
ADMIN_NAME=Admin Fundez
# ADMIN_SYNC_PASSWORD=true

# Mercado Pago Chile
MP_ACCESS_TOKEN=
MP_SANDBOX=true
MP_PAYER_EMAIL=cliente@fundez.cl

WHATSAPP_NUMBER=56912345678
WHATSAPP_DISPLAY=+56 9 1234 5678
SUPPORT_EMAIL=soporte@fundez.cl
# Avisos gratis de Aland (pagos) — sin WhatsApp/Meta
# ADMIN_ALERT_EMAIL=tu@correo.com
# Telegram (gratis): crea bot con @BotFather
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Push gratis al celular: app ntfy + tema privado
# NTFY_TOPIC=fundez-aland-avisos
DPO_EMAIL=privacidad@fundez.cl
PLATFORM_COMMISSION=0.15

MFA_ISSUER=Fundez Admin

ADMIN_IP_ALLOWLIST=
# ADMIN_IP_ALLOWLIST_ENFORCE=true

NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=soporte@fundez.cl
SMTP_PASS=
SMTP_FROM=soporte@fundez.cl

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Florencia IA — contenido e imágenes
FLORENCIA_MODEL=gpt-4o-mini
FLORENCIA_IMAGE_MODEL=gpt-image-1

# Redes sociales oficiales (Florencia nunca publica sin aprobación)
# Meta: Facebook Page + Instagram Business vinculada a la página
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
META_GRAPH_VERSION=v23.0
# LinkedIn Organization (ej. urn:li:organization:123456)
LINKEDIN_ORGANIZATION_URN=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_API_VERSION=202601
# X requiere token OAuth de usuario con permiso tweet.write
X_USER_ACCESS_TOKEN=
# TikTok requiere aprobación de Content Posting API; conexión visible, publicación manual en MVP
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

DTE_PROVIDER=mock
LIBREDTE_URL=https://libredte.cl
LIBREDTE_HASH=
SPLIT_INVOICING=true

SII_PURCHASES_PROVIDER=libredte
SII_PURCHASES_URL=
SII_PURCHASES_API_KEY=

# Solo desarrollo: aceptar passwords legacy en texto plano
# ALLOW_PLAINTEXT_PASSWORDS=true
# HEALTH_VERBOSE=true
# SEED_DEMO_USERS=true
# ALLOW_INSECURE_BOOT=true
